{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GrowBox",
  "identifier": "com.nightpoetry.growbox",
  "build": {
    "frontendDist": "frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GrowBox",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../prompts/agent/system.md": "prompts/agent/system.md",
      "../../prompts/agent/system.zh.md": "prompts/agent/system.zh.md",
      "../../prompts/agent/system.en.md": "prompts/agent/system.en.md",
      "../../prompts/agent/self-evolution-system.md": "prompts/agent/self-evolution-system.md",
      "../../prompts/supervisor/system.md": "prompts/supervisor/system.md",
      "../../prompts/supervisor/check.md": "prompts/supervisor/check.md",
      "../../prompts/gui/system.md": "prompts/gui/system.md",
      "../../prompts/cognitive/framework.md": "prompts/cognitive/framework.md",
      "../../prompts/behavior/guidance.md": "prompts/behavior/guidance.md"
    }
  }
}
