{
  "name": "growbox-gui-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check-i18n": "node ../../../scripts/check-i18n.mjs",
    "build": "node ../../../scripts/check-i18n.mjs && tsc -b && vite build",
    "build:debug": "node ../../../scripts/check-i18n.mjs && tsc -b && VITE_GROWBOX_DEBUG=1 vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@solid-primitives/i18n": "^2.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "puppeteer-core": "^24.43.1",
    "typescript": "~5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0"
  }
}
